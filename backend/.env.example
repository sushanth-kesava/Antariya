# ─── Required ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/antariya
JWT_SECRET=your-strong-random-secret-here-at-least-32-chars
SUPERADMIN_ALLOWED_EMAILS=your-email@gmail.com,another-admin@gmail.com

# ─── Optional: Auth ───────────────────────────────────────────────────────────
JWT_EXPIRES_IN=7d
ADMIN_ALLOWED_EMAILS=admin1@gmail.com,admin2@gmail.com

# ─── Optional: Frontend ───────────────────────────────────────────────────────
FRONTEND_URL=https://antariyaofficial.com,https://www.antariyaofficial.com
PORT=5000
NODE_ENV=development

# ─── Optional: Email / SMTP ───────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="Antariya" <your-email@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM_EMAIL=your-email@gmail.com
MAIL_FROM_NAME=Antariya

# ─── Optional: Cloudinary (Image uploads) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your-api-secret

# ─── Optional: Razorpay (Payments) ───────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── Optional: Delivery ──────────────────────────────────────────────────────
DELHIVERY_API_KEY=your-delhivery-api-key
DELHIVERY_BASE_URL=https://track.delhivery.com

# ─── Optional: Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Optional: Inventory ─────────────────────────────────────────────────────
ORDER_HOLD_MINUTES=30
