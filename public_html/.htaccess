# Antariya — Apache rewrite rules for Next.js static export on Hostinger
# Dynamic routes (product/[id], portal/*, etc.) are client-rendered shells.
# This file rewrites all deep URLs to their pre-built placeholder index.html
# so the React app can hydrate and read the real ID from the URL at runtime.

RewriteEngine On
RewriteBase /

# ══════════════════════════════════════════════════════════════════════════════
# 0. Force HTTPS + redirect www → non-www (canonical URL)
# ══════════════════════════════════════════════════════════════════════════════
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^www\.antariyaofficial\.com$ [NC]
RewriteRule ^ https://antariyaofficial.com%{REQUEST_URI} [L,R=301]

# ══════════════════════════════════════════════════════════════════════════════
# 0b. Strip .html extensions → clean URLs (301 redirect for SEO)
# ══════════════════════════════════════════════════════════════════════════════
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/404\.html$
RewriteRule ^ /%1 [R=301,L]


# ──────────────────────────────────────────────────────────────────────────────
# 1. Product detail pages: /product/<any-id>/ → serve product/placeholder/index.html
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_URI} ^/product/([^/]+)/?$ [NC]
RewriteCond %{REQUEST_URI} !^/product/placeholder
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^product/([^/]+)/?$ /product/placeholder/index.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# 2. Portal customer pages: /portal/customer/*
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portal/customer/(.*)$ /portal/customer/index.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# 3. Portal admin pages: /portal/admin/*
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portal/admin/(.*)$ /portal/admin/index.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# 4. Portal superadmin pages: /portal/superadmin/*
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portal/superadmin/(.*)$ /portal/superadmin/index.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# 5. Order status pages (if dynamic): /order-status/*
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^order-status/(.*)$ /order-status/index.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# 6. Fallback: any non-existing path → 404.html (Next.js generated)
# ──────────────────────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /404.html [L]

# ──────────────────────────────────────────────────────────────────────────────
# Performance & security headers
# ──────────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Cache static assets aggressively
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2?|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML pages — revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compress text-based assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
